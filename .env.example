# PayPal Configuration
# Get these from https://developer.paypal.com/dashboard/applications/live
VITE_PAYPAL_CLIENT_ID=your_client_id_here

# The Secret Key should NOT be used in the frontend (Vite).
# It is only for backend integrations. 
# Keep it safe and NEVER commit it to GitHub.
PAYPAL_SECRET_KEY=your_secret_key_here
